#include <math.h>
#include <stdbool.h>
#include <stdint.h>

#include "complex_{{ type.suffix }}.h"
#include "waveform_gen_{{ type.suffix }}.h"

void gen_time_{{ type.suffix }}({{ type.name }} *t, uint32_t length, uint32_t sample_freq) {
	for (uint32_t i = 0; i < length; i++) {
		t[i] = (({{ type.name }})i) / sample_freq;
	}
}

void gen_freq_{{ type.suffix }}({{ type.name }} *f, uint32_t length, uint32_t sample_freq) {
	for (uint32_t i = 0; i < length; i++) {
		f[i] = ({{ type.name }})0.5 * (({{ type.name }})i) * sample_freq / length;
	}
}

/* Real valued function variants */
void add_sin_{{ type.suffix }}({{ type.name }} *t, {{ type.name }} *x, wave_properties_{{ type.suffix }}_t wave_properties,
			 uint32_t length) {
	for (uint32_t i = 0; i < length; i++) {
		x[i] = x[i] + wave_properties.offset +
			   {{ type.math_prefix }}(wave_properties.amplitude *
				   sin{{ type.math_suffix }}(6.28318530717958647692 * wave_properties.frequency * t[i] +
						6.28318530717958647692 * wave_properties.phase));
	}
}

void add_cos_{{ type.suffix }}({{ type.name }} *t, {{ type.name }} *x, wave_properties_{{ type.suffix }}_t wave_properties,
			 uint32_t length) {
	for (uint32_t i = 0; i < length; i++) {
		x[i] = x[i] + wave_properties.offset +
			   {{ type.math_prefix }}(wave_properties.amplitude *
				   cos{{ type.math_suffix }}(6.28318530717958647692 * wave_properties.frequency * t[i] +
						6.28318530717958647692 * wave_properties.phase));
	}
}

/* Complex valued function variants */
void add_sin_complex_{{ type.suffix }}({{ type.name }} *t, complex_{{ type.suffix }}_t *x, bool write_real, bool write_imag,
					 wave_properties_{{ type.suffix }}_t wave_properties, uint32_t length) {
	if (write_real) {
		for (uint32_t i = 0; i < length; i++) {
			x[i].real = x[i].real + wave_properties.offset +
						{{ type.math_prefix }}(wave_properties.amplitude *
							sin{{ type.math_suffix }}(6.28318530717958647692 * wave_properties.frequency * t[i] +
								 6.28318530717958647692 * wave_properties.phase));
		}
	}
	if (write_imag) {
		for (uint32_t i = 0; i < length; i++) {
			x[i].imag = x[i].imag + wave_properties.offset +
						{{ type.math_prefix }}(wave_properties.amplitude *
							sin{{ type.math_suffix }}(6.28318530717958647692 * wave_properties.frequency * t[i] +
								 6.28318530717958647692 * wave_properties.phase));
		}
	}
}

void add_cos_complex_{{ type.suffix }}({{ type.name }} *t, complex_{{ type.suffix }}_t *x, bool write_real, bool write_imag,
					 wave_properties_{{ type.suffix }}_t wave_properties, uint32_t length) {
	if (write_real) {
		for (uint32_t i = 0; i < length; i++) {
			x[i].real = x[i].real + wave_properties.offset +
						{{ type.math_prefix }}(wave_properties.amplitude *
							cos{{ type.math_suffix }}(6.28318530717958647692 * wave_properties.frequency * t[i] +
								 6.28318530717958647692 * wave_properties.phase));
		}
	}
	if (write_imag) {
		for (uint32_t i = 0; i < length; i++) {
			x[i].imag = x[i].imag + wave_properties.offset +
						{{ type.math_prefix }}(wave_properties.amplitude *
							cos{{ type.math_suffix }}(6.28318530717958647692 * wave_properties.frequency * t[i] +
								 6.28318530717958647692 * wave_properties.phase));
		}
	}
}

void waveform_add_superposition_{{ type.suffix }}(wave_properties_{{ type.suffix }}_t wave_properties,
									   {{ type.name }} *t, {{ type.name }} *x,
									   uint32_t data_length) {
	switch (wave_properties.function_type) {
	case FUNCTION_SINE:
		add_sin_{{ type.suffix }}(t, x, wave_properties, data_length);
		break;
	case FUNCTION_COS:
		add_cos_{{ type.suffix }}(t, x, wave_properties, data_length);
		break;
	default:
		break;
	}
}

void waveform_add_superposition_complex_{{ type.suffix }}(wave_properties_{{ type.suffix }}_t wave_properties, {{ type.name }} *t,
								   complex_{{ type.suffix }}_t *x, bool write_real,
								   bool write_imag, uint32_t data_length) {
	switch (wave_properties.function_type) {
	case FUNCTION_SINE:
		add_sin_complex_{{ type.suffix }}(t, x, write_real, write_imag, wave_properties,
						data_length);
		break;
	case FUNCTION_COS:
		add_cos_complex_{{ type.suffix }}(t, x, write_real, write_imag, wave_properties,
						data_length);
		break;
	default:
		break;
	}
}

void init_waveform_{{ type.suffix }}(wave_settings_{{ type.suffix }}_t wave_settings, {{ type.name }} *t, {{ type.name }} *x) {
	/* Generate the time according to settings first */
	gen_time_{{ type.suffix }}(t, wave_settings.data_length, wave_settings.fs);
	/* Now generate the main waveform */
	for (uint8_t i = 0; i < wave_settings.num_superpositions; i++) {
		waveform_add_superposition_{{ type.suffix }}(wave_settings.superposition[i], t, x,
								   wave_settings.data_length);
	}
	/* Add in the DC offset for the signal */
	for (uint32_t i = 0; i < wave_settings.data_length; i++) {
		x[i] += wave_settings.dc_offset;
	}
}

void init_waveform_complex_{{ type.suffix }}(wave_settings_complex_{{ type.suffix }}_t wave_settings, {{ type.name }} *t,
						   complex_{{ type.suffix }}_t *x) {
	/* Generate the time according to settings first */
	gen_time_{{ type.suffix }}(t, wave_settings.data_length, wave_settings.fs);
	/* Now generate the main waveform */
	for (uint8_t i = 0; i < wave_settings.num_superpositions; i++) {
		/* Add to the real parts based on the waveform settings */
		if (wave_settings.superposition_real) {
			waveform_add_superposition_complex_{{ type.suffix }}(wave_settings.superposition_real[i],
										   t, x, true, false,
										   wave_settings.data_length);
		}
		/* Add to the imaginary parts based on the waveform settings */
		if (wave_settings.superposition_imag) {
			waveform_add_superposition_complex_{{ type.suffix }}(wave_settings.superposition_imag[i],
										   t, x, false, true,
										   wave_settings.data_length);
		}
	}
	/* Add in the DC offset for the signal */
	for (uint32_t i = 0; i < wave_settings.data_length; i++) {
		x[i].real += wave_settings.dc_offset.real;
		x[i].imag += wave_settings.dc_offset.imag;
	}
}

void scale_waveform_{{ type.suffix }}({{ type.name }} *x, {{ type.name }} scale_factor, uint32_t length) {
	for (uint32_t i = 0; i < length; i++) {
		x[i] *= scale_factor;
	}
}

void divide_waveform_{{ type.suffix }}({{ type.name }} *x, {{ type.name }} scale_factor, uint32_t length) {
	if (scale_factor == ({{ type.name }})0) {
		return;
	}
	for (uint32_t i = 0; i < length; i++) {
		x[i] /= scale_factor;
	}
}

void scale_waveform_complex_{{ type.suffix }}(complex_{{ type.suffix }}_t *x, {{ type.name }} scale_factor, uint32_t length) {
	for (uint32_t i = 0; i < length; i++) {
		x[i].real *= scale_factor;
		x[i].imag *= scale_factor;
	}
}

void divide_waveform_complex_{{ type.suffix }}(complex_{{ type.suffix }}_t *x, {{ type.name }} scale_factor, uint32_t length) {
	if (scale_factor == ({{ type.name }})0) {
		return;
	}
	for (uint32_t i = 0; i < length; i++) {
		x[i].real /= scale_factor;
		x[i].imag /= scale_factor;
	}
}

void mask_waveform_{{ type.suffix }}({{ type.name }} *x, uint32_t bit_width, uint32_t length) {
	if (bit_width == 0 || bit_width > 64) {
		return;
	}

	int64_t max_limit = (int64_t)(((uint64_t)1 << (bit_width - 1)) - 1);
	int64_t min_limit = (int64_t)-(int64_t)(((uint64_t)1 << (bit_width - 1)) - 1) - 1;

	{{ type.name }} max_val = ({{ type.name }})max_limit;
	{{ type.name }} min_val = ({{ type.name }})min_limit;

	for (uint32_t i = 0; i < length; i++) {
		if (x[i] > max_val) {
			x[i] = max_val;
		} else if (x[i] < min_val) {
			x[i] = min_val;
		}
	}
}

void mask_waveform_complex_{{ type.suffix }}(complex_{{ type.suffix }}_t *x, uint32_t bit_width, uint32_t length) {
	if (bit_width == 0 || bit_width > 64) {
		return;
	}

	int64_t max_limit = (int64_t)(((uint64_t)1 << (bit_width - 1)) - 1);
	int64_t min_limit = (int64_t)-(int64_t)(((uint64_t)1 << (bit_width - 1)) - 1) - 1;

	{{ type.name }} max_val = ({{ type.name }})max_limit;
	{{ type.name }} min_val = ({{ type.name }})min_limit;

	for (uint32_t i = 0; i < length; i++) {
		if (x[i].real > max_val) {
			x[i].real = max_val;
		} else if (x[i].real < min_val) {
			x[i].real = min_val;
		}

		if (x[i].imag > max_val) {
			x[i].imag = max_val;
		} else if (x[i].imag < min_val) {
			x[i].imag = min_val;
		}
	}
}
