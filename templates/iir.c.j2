#include "iir_{{ type }}.h"

#include <stdint.h>

void iir_filter_{{ type }}({{ type }} *data_in, {{ type }} *data_out, struct iir_{{ type }}_t *filter,
				uint32_t length) {
	uint8_t N = filter->taps;
	uint32_t c, i, j;

	for (j = 0; j < length; j++) {
		data_out[j] = ({{ type }})0;
	}

	for (c = 0; c < length; c++) {
		filter->in_buff[(c + filter->cycle) % N] = data_in[c];
		for (i = 0; i < N; i++) {
			data_out[c] = data_out[c] +
						  (filter->b[i] *
						   filter->in_buff[(c + filter->cycle - i + N) % N]);
		}
		for (i = 1; i < N; i++) {
			data_out[c] = data_out[c] -
						  (filter->a[i] *
						   filter->out_buff[(c + filter->cycle - i + N) % N]);
		}

		data_out[c] = data_out[c] / filter->a[0];
		filter->out_buff[(c + filter->cycle) % N] = data_out[c];
	}
	filter->cycle = (c + filter->cycle) % N;
}

/* All biquad sections will have 3 coefficients on each denominator: */
/* a0, a1, a2, b0, b1, b2 */
#define BIQUAD_FILT_TAPS 3
void biquad_section_filter_{{ type }}({{ type }} *data_in, {{ type }} *data_out,
						   struct biquad_section_{{ type }}_t *section, uint32_t length) {
	uint32_t c, i, j;

	for (j = 0; j < length; j++) {
		data_out[j] = ({{ type }})0;
	}

	for (c = 0; c < length; c++) {
		section->in_buff[(c + section->cycle) % BIQUAD_FILT_TAPS] = data_in[c];
		for (i = 0; i < BIQUAD_FILT_TAPS; i++) {
			data_out[c] =
				data_out[c] +
				(section->b[i] *
				 section->in_buff[(c + section->cycle - i + BIQUAD_FILT_TAPS) %
								  BIQUAD_FILT_TAPS]);
		}
		for (i = 1; i < BIQUAD_FILT_TAPS; i++) {
			data_out[c] =
				data_out[c] -
				(section->a[i] *
				 section->out_buff[(c + section->cycle - i + BIQUAD_FILT_TAPS) %
								   BIQUAD_FILT_TAPS]);
		}

		data_out[c] = data_out[c] / section->a[0];
		section->out_buff[(c + section->cycle) % BIQUAD_FILT_TAPS] =
			data_out[c];
	}
	section->cycle = (c + section->cycle) % BIQUAD_FILT_TAPS;
}

void sos_filter_{{ type }}({{ type }} *data_in, {{ type }} *data_out, struct sos_filter_{{ type }}_t *filter,
				uint32_t length) {

	{{ type }} data_in_buff[32] = {({{ type }})0};
	for (uint32_t i = 0; i < length; i++) {
		data_in_buff[i] = data_in[i];
	}
	for (uint32_t i = 0; i < filter->num_sections; i++) {
		biquad_section_filter_{{ type }}(data_in_buff, data_out,
							  &filter->biquad_section[i], length);
		for (uint32_t j = 0; j < length; j++) {
			data_in_buff[j] = data_out[j];
		}
	}

	for (uint32_t j = 0; j < length; j++) {
		data_out[j] = filter->gain * data_out[j];
	}
}
